using namespace std;  

int RandomNumber(int From, int To)
{
 int randNum = rand() % (To - From + 1) + From;

 return randNum;
}

void FillMatrixWithRandomNumbers(int Matrix[3][3], int Rows, int Columns)
{
 for (int i = 0; i <= Rows - 1; i++)
 {
  for (int j = 0; j <= Columns - 1; j++)
  {
   Matrix[i][j] = RandomNumber(1, 100);
  }
 }
}

void PrintMatrix(int Matrix[3][3], int Rows, int Columns)
{
 for (int i = 0; i <= Rows - 1; i++)
 {
  for (int j = 0; j <= Columns - 1; j++)
  {
   cout << setw(3) << Matrix[i][j] << " ";
  }

  cout << endl;
 }
}

int SumRow(int arr[3][3], int Columns, int NumberOfRow)
{
 int Sum = 0;

 for (int i = 0; i <= Columns - 1; i++)
 {
  Sum += arr[NumberOfRow][i];
 }

 return Sum;
}

void PrintEachRowSum(int arr[3][3], int Rows, int Columns)
{
 cout << "\n The following are the sum of each row in the matrix : \n" << endl;

 for (int i = 0; i <= Rows - 1; i++)
 {
  cout << " Row " << i + 1 << " Sum = " << SumRow(arr, Columns, i) << endl;
 }
}

int main()
{
 srand((unsigned)time(NULL));

 int arr[3][3];

 FillMatrixWithRandomNumbers(arr, 3, 3);

 cout << " The following is a 3x3 random matrix : \n";
 PrintMatrix(arr, 3, 3);

 PrintEachRowSum(arr, 3, 3);

 return 0;
}
