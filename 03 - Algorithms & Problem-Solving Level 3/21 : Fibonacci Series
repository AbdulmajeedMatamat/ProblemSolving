#include <iostream>   
#include <iomanip>
#include <cstdlib>

using namespace std;  

void PrintFibonacciUsingLoop(short Number)
{
 int Prev1 = 1, Prev2 = 0, FibonacciNumber = 0;

 cout << "1   ";

 for (short i = 2; i <= Number; i++)
 {
  FibonacciNumber = Prev1 + Prev2;

  cout << FibonacciNumber << "   ";

  Prev2 = Prev1;

  Prev1 = FibonacciNumber;
 }
 
}

int main()
{ 
 PrintFibonacciUsingLoop(10);

 return 0;
}
