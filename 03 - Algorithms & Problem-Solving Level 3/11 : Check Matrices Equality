#include <iostream>   
#include <iomanip>
#include <cstdlib>

using namespace std;  

int RandomNumber(int From, int To)
{
 int randNum = rand() % (To - From + 1) + From;

 return randNum;
}

void FillMatrixWithRandomNumbers(int Matrix[3][3], int Rows, int Columns)
{
 for (short i = 0; i <= Rows - 1; i++)
 {
  for (short j = 0; j <= Columns - 1; j++)
  {
   Matrix[i][j] = RandomNumber(1, 10);
  }
 }
}

int SumOfMatrix(int Matrix[3][3], short Rows, short Columns)
{
 int Sum = 0;

 for (short i = 0; i <= Rows - 1; i++)
 {
  for (short j = 0; j <= Columns - 1; j++)
  {
   Sum += Matrix[i][j];
  }
 }

 cout << endl;

 return Sum;
}

void PrintMatrix(int Matrix[3][3], int Rows, int Columns)
{
 for (short i = 0; i <= Rows - 1; i++)
 {
  for (short j = 0; j <= Columns - 1; j++)
  {
   printf(" %0*d    ", 2, Matrix[i][j]);
  }

  cout << endl;
 }
}

bool AreEqualityMatrices(int Matrix1[3][3], int Matrix2[3][3], short Rows, short Columns)
{
 return (SumOfMatrix(Matrix1, Rows, Columns) == SumOfMatrix(Matrix2, Rows, Columns));
}

int main()
{
 srand((unsigned)time(NULL));

 int Matrix1[3][3];
 int Matrix2[3][3];

 FillMatrixWithRandomNumbers(Matrix1, 3, 3);
 cout << " Matrix1 : \n";
 PrintMatrix(Matrix1, 3, 3);

 FillMatrixWithRandomNumbers(Matrix2, 3, 3);
 cout << "\n Matrix2 : \n";
 PrintMatrix(Matrix2, 3, 3);


 if (AreEqualityMatrices(Matrix1, Matrix2, 3, 3))
  cout << "Yes : both Matrices are Equality.\n ";
 else
  cout << "No : Matrices are NOT Equality.\n ";

 return 0;
}
